# Python bytecode — never commit these
__pycache__/
*.py[cod]
*.pyo

# Virtual environments — always too large and platform-specific
.venv/
venv/
env/
.env/

# Build / packaging artifacts
dist/
build/
*.egg-info/
*.egg

# Test and coverage artifacts
.pytest_cache/
.coverage
htmlcov/

# IDE config folders
.vscode/
.idea/
*.swp
*.swo

# macOS metadata
.DS_Store

# Jupyter checkpoint folders
.ipynb_checkpoints/

# Database files - TOO BIG FOR GITHUB
*.db
*.sqlite
*.sqlite3
*.csv

